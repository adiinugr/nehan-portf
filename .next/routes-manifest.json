{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/demo/travel/[id]",
      "regex": "^/demo/travel/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/demo/travel/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/demo/barbershop",
      "regex": "^/demo/barbershop(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/barbershop(?:/)?$"
    },
    {
      "page": "/demo/hotel",
      "regex": "^/demo/hotel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/hotel(?:/)?$"
    },
    {
      "page": "/demo/rental",
      "regex": "^/demo/rental(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/rental(?:/)?$"
    },
    {
      "page": "/demo/travel",
      "regex": "^/demo/travel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/travel(?:/)?$"
    },
    {
      "page": "/demo/travel/destinasi",
      "regex": "^/demo/travel/destinasi(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/travel/destinasi(?:/)?$"
    },
    {
      "page": "/demo/travel/kontak",
      "regex": "^/demo/travel/kontak(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/travel/kontak(?:/)?$"
    },
    {
      "page": "/demo/travel/paket",
      "regex": "^/demo/travel/paket(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo/travel/paket(?:/)?$"
    },
    {
      "page": "/education",
      "regex": "^/education(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/education(?:/)?$"
    },
    {
      "page": "/layanan",
      "regex": "^/layanan(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/layanan(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/projects",
      "regex": "^/projects(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicons/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$"
    }
  ]
}